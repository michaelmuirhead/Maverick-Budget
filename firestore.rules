rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles - each user can read/write their own profile
    match /users/{userId}/profile/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Households - any authenticated user can create
    // Members can read/write household doc and its sub-collections
    match /households/{householdId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Budget data under household
      match /data/{doc} {
        allow read, write: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
      }
    }
  }
}
