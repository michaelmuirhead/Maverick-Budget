{
  "name": "maverick-budget",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal YNAB-style budget PWA with Firebase sync",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -b",
    "wipe:dry": "node scripts/wipe-firestore.mjs",
    "wipe:confirm": "node scripts/wipe-firestore.mjs --confirm",
    "rules:deploy": "node scripts/deploy-firestore-rules.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "firebase": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "firebase-admin": "^13.8.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.21.0"
  }
}
